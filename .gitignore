venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# Fichiers Python compilés
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo
*.pyc
*.pyw

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Logs
*.log
leyamo.log

# Base de données SQLite (si tu en utilises une)
*.db
*.sqlite
*.sqlite3

# Fichiers d'environnement (sensible)
.env
.env.local
.env.production
.env.development

# Dossiers d'upload (images locales)
uploads/
static/uploads/
media/

# Fichiers IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Tests et coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json

# Déploiement (Vercel)
.vercel/